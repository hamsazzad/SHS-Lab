<?xml version="1.0" encoding="utf-8"?>
<resources>
    <style name="Theme.SHSLab" parent="Theme.MaterialComponents.DayNight.NoActionBar">
        <item name="colorPrimary">@color/accent_cyan</item>
        <item name="colorPrimaryDark">@color/primary_dark</item>
        <item name="colorAccent">@color/accent_cyan</item>
        <item name="android:windowBackground">@color/bg_dark</item>
        <item name="android:statusBarColor">@color/primary_dark</item>
        <item name="android:navigationBarColor">@color/primary_dark</item>
        <item name="colorSurface">@color/glass_card</item>
        <item name="colorOnSurface">@color/text_primary</item>
        <item name="alertDialogTheme">@style/SHSDialog</item>
        <item name="materialAlertDialogTheme">@style/SHSDialog</item>
    </style>

    <style name="SHSDialog" parent="ThemeOverlay.MaterialComponents.MaterialAlertDialog">
        <item name="android:background">@color/glass_card</item>
        <item name="colorOnSurface">@color/text_primary</item>
        <item name="colorPrimary">@color/accent_cyan</item>
        <item name="buttonBarPositiveButtonStyle">@style/SHSButton</item>
    </style>

    <style name="SHSButton" parent="Widget.MaterialComponents.Button.TextButton">
        <item name="android:textColor">@color/accent_cyan</item>
    </style>
</resources>
